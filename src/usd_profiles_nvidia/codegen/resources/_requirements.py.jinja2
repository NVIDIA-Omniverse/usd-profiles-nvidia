from enum import Enum

from ._api import Requirement
from ._parameters import Parameters
from ._examples import Examples


class Requirements(Requirement, Enum):
    """
    An enumeration of all requirements.
    """
    # Validators are Sphinx-only metadata today; generated enums intentionally keep validator as None.
    {%- for requirement in requirements %}
    {{ requirement.enum_id_version }} = (
        {{ requirement.namespaced_id | tojson }},
        {{ requirement.version | tojson if requirement.version else 'None' }},
        {{ requirement.display_name | tojson }},
        {{ requirement.message | tojson }},
        {{ requirement.html_path | tojson if requirement.html_path else 'None' }},
        {{ requirement.compatibility | tojson if requirement.compatibility else 'None' }},
        None,
        {%- if requirement.tags %}
        (
            {%- for tag in requirement.tags %}
            {{ tag | tojson }},
            {%- endfor %}
        ),
        {%- else %}
        (),
        {%- endif %}
        {%- if requirement.parameters %}
        (
            {%- for param in requirement.parameters %}
            Parameters.{{ param.enum_name }},
            {%- endfor %}
        ),
        {%- else %}
        (),
        {%- endif %}
        {%- if requirement.examples %}
        (
            {%- for example in requirement.examples %}
            Examples.{{ example.enum_name }},
            {%- endfor %}
        ),
        {%- else %}
        (),
        {%- endif %}
    )
    {%- endfor %}
    # Aliases for latest values
    {%- for requirement in requirements.latest_values() if requirement.enum_id != requirement.enum_id_version %}
    {{ requirement.enum_id }} = {{ requirement.enum_id_version }}
    {%- endfor %}
